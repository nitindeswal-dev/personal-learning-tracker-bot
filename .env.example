# Copy this file to .env and fill in real values.
# Never commit .env.

# 1) Get this from @BotFather in Telegram (/newbot flow).
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-botfather

# 2) Get this from https://cognee.ai.
COGNEE_API_KEY=sk-your-real-cognee-key

# 3) Cognee Cloud base URL.
COGNEE_API_BASE_URL=https://api.cognee.ai

# 4) OPTIONAL allowlist of Telegram numeric user IDs permitted to use the bot.
#    - Leave EMPTY for OPEN access (anyone who finds your bot can use it).
#      This is the right choice for the hackathon live demo so judges + visitors
#      can try the bot instantly.
#    - Set to a comma-separated list of numeric IDs to lock the bot down to
#      specific users. Get your own ID by messaging @userinfobot in Telegram.
#    Examples:
#      ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# 5) OPTIONAL: max messages per minute per user (anti-abuse for the open demo).
#    Defaults to 10 if unset. Set to 0 to disable rate limiting.
RATE_LIMIT_PER_MIN=10

# 6) Port for the keep-alive HTTP server (only used when deployed to HF Spaces).
KEEP_ALIVE_PORT=7860

# 7) OPTIONAL: Telegram API reverse proxy (needed on HF Spaces which blocks api.telegram.org).
#    Deploy a Cloudflare Worker that proxies api.telegram.org, then set the URL here.
#    Leave empty when running locally.
TELEGRAM_PROXY_URL=
